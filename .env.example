# ------------------------------
# Bilibili auth (optional)
# ------------------------------
# Required for members-only / login-gated content.
BILI_SESSDATA=
BILI_BILI_JCT=
BILI_BUVID3=
BILI_COOKIES_FILE=
# Recommended for desktop use after logging in to bilibili in your browser:
# YTDLP_COOKIES_FROM_BROWSER=edge
# YTDLP_COOKIES_FROM_BROWSER=chrome
YTDLP_COOKIES_FROM_BROWSER=
YTDLP_AUTO_COOKIES_FROM_BROWSER=1
YTDLP_MIN_VERSION=2025.01.15

# ------------------------------
# Core pipeline
# ------------------------------
WHISPER_MODEL=tiny
ASR_BEAM_SIZE=1
ASR_VAD_MIN_SILENCE_MS=1000
OUTPUT_DIR=./output
TOP_N=10
ENABLE_FEEDBACK_RANKING=1
# FEEDBACK_RANKER_PATH=./output/_api_jobs/_feedback/ranker_model.json
ENABLE_LLM_RERANK=0
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_MAX_CANDIDATES=20
LLM_SCORE_WEIGHT=0.65
LLM_TIMEOUT_SEC=30
ENABLE_SEMANTIC_ENRICHMENT=0
SEMANTIC_MODEL=
SEMANTIC_MAX_CANDIDATES=8
SEMANTIC_SCORE_WEIGHT=0.2
SEMANTIC_TIMEOUT_SEC=30
ENABLE_BOUNDARY_ADAPTATION=1
# BOUNDARY_PROFILE_PATH=./output/_api_jobs/_feedback/boundary_profile.json
# ADJUSTMENT_LOG_PATH=./output/_api_jobs/_feedback/clip_adjustments.jsonl
ADAPTIVE_PADDING=1
HALF_PEAK_RATIO=0.5

# ------------------------------
# API mode
# ------------------------------
# lite: local single-node mode (no redis/postgres required)
# full: full SaaS mode (requires redis/postgres/minio)
# auto: try full then fallback to lite
API_MODE=lite

# ------------------------------
# API security / web
# ------------------------------
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
API_RATE_LIMIT_RPM=180

# Lite mode local queue concurrency
LITE_MAX_CONCURRENT_JOBS=1
LITE_MAX_UPLOAD_MB=4096
# Optional: restrict user-selected output_dir under a trusted base folder
# LITE_OUTPUT_BASE_DIR=D:\\clips

# ------------------------------
# Worker reliability
# ------------------------------
WORKER_CMD_TIMEOUT_SEC=1200
WORKER_YTDLP_TIMEOUT_SEC=900
WORKER_FFMPEG_TIMEOUT_SEC=900
WORKER_FFPROBE_TIMEOUT_SEC=30
WORKER_CMD_RETRIES=2
CLIP_FFMPEG_PRESET=ultrafast
CLIP_FFMPEG_CRF=23
CLIP_FFMPEG_AUDIO_BITRATE=160k
CLIP_FFMPEG_WORKERS=4

# Inference client retry
INFERENCE_TIMEOUT_SEC=600
INFERENCE_RETRIES=2

# ------------------------------
# Full-stack services (docker-compose)
# ------------------------------
DATABASE_URL=postgresql://clipper:clipper@localhost:5432/stream_clipper
REDIS_URL=redis://localhost:6379/0
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=stream-clipper
S3_REGION=us-east-1
JWT_SECRET=change-me-in-production-use-a-real-secret
INFERENCE_URL=http://localhost:8001
